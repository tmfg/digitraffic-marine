# Whitelist-style gitignore: ignore everything except tracked files

# Ignore everything by default
*

# Root files
!.editorconfig
!.gitignore
!LICENSE.txt
!README.md
!ais-portforward.sh
!check-dependency-updates.sh
!clean-logs.sh
!owasp-suppressions.xml
!pom.xml
!pooki-portforward.sh
!portnet-portforward.sh
!versions-maven-plugin-rules.xml

# .github directory
!.github/
!.github/**

# common directory
!common/
!common/**

# dbmarine directory
!dbmarine/
!dbmarine/**

# lib directory (submodule)
!lib/
!lib/digitraffic-common-java

# mqttmarine directory
!mqttmarine/
!mqttmarine/**

# scripts directory
!scripts/
!scripts/**

# src directory
!src/
!src/**